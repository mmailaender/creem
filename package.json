{
  "name": "@creem_io/better-auth",
  "version": "1.0.2",
  "packageManager": "pnpm@10.16.0",
  "description": "Creem official Better-Auth plugin",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:package-json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:package-json": "echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "prettier --check \"src/**/*.ts\""
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./client": {
      "types": "./dist/esm/client.d.ts",
      "import": "./dist/esm/client.js",
      "require": "./dist/cjs/client.js"
    },
    "./create-creem-auth-client": {
      "types": "./dist/esm/create-creem-auth-client.d.ts",
      "import": "./dist/esm/create-creem-auth-client.js",
      "require": "./dist/cjs/create-creem-auth-client.js"
    },
    "./server": {
      "types": "./dist/esm/creem-server.d.ts",
      "import": "./dist/esm/creem-server.js",
      "require": "./dist/cjs/creem-server.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/package.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/armitage-labs/creem-betterauth.git"
  },
  "keywords": [
    "creem",
    "betterauth",
    "better-auth",
    "payment",
    "subscription",
    "stripe-alternative"
  ],
  "author": "Creem",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/armitage-labs/creem-betterauth/issues"
  },
  "homepage": "https://github.com/armitage-labs/creem-betterauth#readme",
  "devDependencies": {
    "@better-auth/core": "^1.5.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "better-auth": "^1.3.34",
    "better-call": "^2.0.1",
    "better-sqlite3": "^12.4.1",
    "creem": "^1.3.6",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "zod": "^3.23.8"
  },
  "dependencies": {
    "creem": "^1.4.1"
  },
  "peerDependencies": {
    "better-auth": "^1.3.34",
    "zod": "^3.23.8 || ^4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
